<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net8.0-windows</TargetFramework>
		<Nullable>disable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UseWPF>False</UseWPF>
		<Platforms>x86;x64</Platforms>
	</PropertyGroup>

	<PropertyGroup>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Platform)'=='x64'">
		<OutputPath>C:\Program Files (x86)\Datacomp\BIM Vision\plugins_x64\my_plugin\</OutputPath>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Platform)'=='x86'">
		<OutputPath>C:\Program Files (x86)\Datacomp\BIM Vision\plugins\my_plugin\</OutputPath>
	</PropertyGroup>

	<ItemGroup>
	  <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
	</ItemGroup>

	<ItemGroup>
	  <Reference Include="System.Windows.Forms">
	    <HintPath>C:\Program Files (x86)\Reference Assemblies\Microsoft\Framework\.NETFramework\v4.5.2\System.Windows.Forms.dll</HintPath>
	  </Reference>
	</ItemGroup>

</Project>
